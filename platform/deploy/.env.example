# Copy this file to .env for machine-local overrides.
# Values below are development placeholders only.

POSTGRES_DB=metadata_platform
POSTGRES_USER=metadata_app
POSTGRES_PASSWORD=metadata_app_dev_password
POSTGRES_PORT=5432

REDIS_PORT=6379

# Spring Boot local profile defaults aligned with the compose services.
METADATA_DB_URL=jdbc:postgresql://localhost:5432/metadata_platform
METADATA_DB_USERNAME=metadata_app
METADATA_DB_PASSWORD=metadata_app_dev_password
METADATA_REDIS_HOST=localhost
METADATA_REDIS_PORT=6379
